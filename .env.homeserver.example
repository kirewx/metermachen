# .env für den Home-Server — als .env neben docker-compose.homeserver.yml ablegen.
# docker compose liest .env automatisch ein. NICHT ins Git committen.

# --- Pflicht ---------------------------------------------------------------

# Session-Signierung. Erzeugen mit:  openssl rand -hex 32
SECRET_KEY=

# Passwort des Admin-Accounts (Login: admin / <hier>).
ADMIN_PASSWORD=

# Öffentliche Basis-URL, unter der die App über den Tunnel erreichbar ist.
# Muss exakt dem "Public hostname" im Cloudflare-Tunnel entsprechen.
PUBLIC_BASE_URL=https://metermachen.jasperz.de

# Token des Cloudflare-Tunnels (Zero Trust → Networks → Tunnels → Connector-Token).
# Sieht aus wie ein langer Base64-String. Enthält das Tunnel-Geheimnis — wie ein Passwort behandeln.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Optional --------------------------------------------------------------

# Abweichender Admin-Benutzername (Standard: admin).
#ADMIN_USER=admin

# --- Strava-Integration (alle drei setzen, um sie zu aktivieren) -----------
# API-App: https://www.strava.com/settings/api
#   - Authorization Callback Domain dort = nur der Hostname (also metermachen.jasperz.de)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Frei wählbarer Geheim-String, der die Webhook-Validierung absichert:
STRAVA_WEBHOOK_VERIFY_TOKEN=
