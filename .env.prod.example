# Produktions-.env für den VPS — als .env neben docker-compose.prod.yml ablegen.
# docker compose liest .env automatisch ein.

# --- Pflicht ---------------------------------------------------------------

# Session-Signierung. Erzeugen mit:  openssl rand -hex 32
SECRET_KEY=

# Passwort des Admin-Accounts (Login: admin / <hier>).
ADMIN_PASSWORD=

# Domain, unter der die App läuft (NUR Hostname, kein https://, kein Pfad).
# Muss per DNS auf die Server-IP zeigen. Caddy holt dafür automatisch ein Zertifikat.
DOMAIN=meter.example.com

# Öffentliche Basis-URL = https:// + DOMAIN. Wird für Strava-OAuth + Webhook genutzt.
PUBLIC_BASE_URL=https://meter.example.com

# --- Optional --------------------------------------------------------------

# Abweichender Admin-Benutzername (Standard: admin).
#ADMIN_USER=admin

# --- Strava-Integration (alle vier setzen, um sie zu aktivieren) -----------
# API-App: https://www.strava.com/settings/api
#   - Authorization Callback Domain dort = nur die DOMAIN (z. B. meter.example.com)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Frei wählbarer Geheim-String, der die Webhook-Validierung absichert:
STRAVA_WEBHOOK_VERIFY_TOKEN=
# Stichtag (ISO-Datum): Strava-Aktivitäten vor diesem Datum werden nie
# importiert — weder beim Backfill noch per Webhook. Leer = kein Stichtag.
#STRAVA_IMPORT_SINCE=2026-07-11
