# Kopie als .env ablegen — docker compose liest sie automatisch ein.

# Pflicht: Schlüssel für Session-Signierung (z. B. `openssl rand -hex 32`).
SECRET_KEY=

# Pflicht: Passwort des Admin-Accounts.
ADMIN_PASSWORD=

# Optional: Benutzername des Admin-Accounts (Standard: admin).
#ADMIN_USER=admin

# Optional, nur lokale Entwicklung ohne Docker:
# Datenverzeichnis (Standard: ./data) bzw. abweichende Datenbank-URL.
#DATA_DIR=./data
#DATABASE_URL=

# Optional: 1 setzen, um das Seeding der Demodaten zu überspringen.
#METER_SKIP_SEED=1

# Optional: Strava-Integration. Alle vier Werte setzen, um sie zu aktivieren.
# API-App anlegen unter https://www.strava.com/settings/api
#STRAVA_CLIENT_ID=
#STRAVA_CLIENT_SECRET=
# Frei wählbarer String, der die Webhook-Validierung absichert:
#STRAVA_WEBHOOK_VERIFY_TOKEN=
# Öffentlich per HTTPS erreichbare Basis-URL der App (für OAuth-Redirect + Webhook):
#PUBLIC_BASE_URL=https://meter.example.com
